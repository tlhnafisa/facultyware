<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Kontrol Dokumen FTI</title>
    <link rel="stylesheet" href="/assets/styles.css">
    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="/assets/js/sidebar.js?v=0.3.11" defer></script>
</head>
<body>
    <aside id="sidebar" class="sidebar" data-side="left" aria-hidden="false">
        <nav aria-label="Sidebar navigation">
            <header>
                <a href="/home" class="btn-ghost p-2 h-12 w-full justify-start">
                    <div class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg">📄</div>
                    <div class="grid flex-1 text-left text-sm leading-tight">
                        <span class="truncate font-medium">Dokumen Kontrol</span>
                        <span class="truncate text-xs">FTI</span>
                    </div>
                </a>
            </header>
            <section class="scrollbar">
                <div role="group" aria-labelledby="group-menu">
                    <h3 id="group-menu">Menu</h3>
                    <ul>
                        <li>
                            <a href="/home">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
                                <span>Beranda</span>
                            </a>
                        </li>
                        <li>
                            <a href="/dokumen" aria-current="page">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                <span>Daftar Dokumen</span>
                            </a>
                        </li>
                        <li>
                            <a href="/profile">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                <span>Profil Saya</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </section>
            <footer>
                <div class="flex items-center gap-2 p-2">
                    <div class="flex aspect-square size-8 items-center justify-center rounded-lg bg-sidebar-primary text-sidebar-primary-foreground font-bold"><%= user.name.charAt(0).toUpperCase() %></div>
                    <div class="grid flex-1 text-left text-sm leading-tight">
                        <span class="truncate font-medium"><%= user.name %></span>
                        <span class="truncate text-xs"><%= user.role %></span>
                    </div>
                    <a href="/logout" class="btn-ghost btn-icon size-8"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></a>
                </div>
            </footer>
        </nav>
    </aside>

    <main id="content" class="p-6">
        <div class="mb-6">
            <h1 class="text-2xl font-bold">Daftar Dokumen</h1>
            <p class="text-muted-foreground">Dokumen yang telah dipublish</p>
        </div>

        <!-- Filter & Search -->
        <div class="card mb-6">
            <section>
                <form action="/dokumen" method="GET" class="flex gap-3 flex-wrap">
                    <input type="text" name="search" class="input flex-1" placeholder="Cari nama dokumen..." value="<%= search %>">
                    <select name="kategori_id" class="input" style="width: auto;">
                        <option value="">-- Semua Kategori --</option>
                        <% kategori.forEach(k => { %>
                            <option value="<%= k.id %>" <%= kategori_id == k.id ? 'selected' : '' %>><%= k.name %></option>
                        <% }) %>
                    </select>
                    <button type="submit" class="btn">Cari</button>
                    <% if (search || kategori_id) { %>
                        <a href="/dokumen" class="btn-outline">Reset</a>
                    <% } %>
                </form>
            </section>
        </div>

        <!-- Daftar Dokumen -->
        <div class="card">
            <section>
                <% if (dokumen.length === 0) { %>
                    <div class="text-center py-12">
                        <p class="text-muted-foreground">Belum ada dokumen yang dipublish.</p>
                    </div>
                <% } else { %>
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b">
                                <th class="text-left py-3 px-4 font-medium text-muted-foreground">No</th>
                                <th class="text-left py-3 px-4 font-medium text-muted-foreground">Nama Dokumen</th>
                                <th class="text-left py-3 px-4 font-medium text-muted-foreground">Kategori</th>
                                <th class="text-left py-3 px-4 font-medium text-muted-foreground">No. Dokumen</th>
                                <th class="text-left py-3 px-4 font-medium text-muted-foreground">Ruang Lingkup</th>
                                <th class="text-left py-3 px-4 font-medium text-muted-foreground">Versi</th>
                                <th class="text-left py-3 px-4 font-medium text-muted-foreground">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% dokumen.forEach((d, i) => { %>
                                <tr class="border-b">
                                    <td class="py-3 px-4"><%= i + 1 %></td>
                                    <td class="py-3 px-4 font-medium"><%= d.name %></td>
                                    <td class="py-3 px-4"><%= d.kategori_name || '-' %></td>
                                    <td class="py-3 px-4"><%= d.doc_no || '-' %></td>
                                    <td class="py-3 px-4"><%= d.scope || '-' %></td>
                                    <td class="py-3 px-4"><%= d.rev_no ? 'v' + d.rev_no : '-' %></td>
                                    <td class="py-3 px-4">
                                        <div class="flex gap-2">
                                            <a href="/dokumen/<%= d.id %>" class="btn-outline btn-sm">Detail</a>
                                            <% if (d.uploaded_file) { %>
                                                <a href="/uploads/<%= d.uploaded_file %>" target="_blank" class="btn-sm btn-outline">Unduh</a>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } %>
            </section>
        </div>
    </main>
    <div id="toaster" class="toaster"></div>
</body>
</html>